<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.KotlinRoomDatabase" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/yadro_dark_button</item>
        <item name="colorPrimaryVariant">@color/yadro_dark_variant</item>
        <item name="colorOnPrimary">@color/photo_dark_background</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/yadro_dark_button</item>
        <item name="colorSecondaryVariant">@color/yadro_dark_button</item>
        <item name="colorOnSecondary">@color/photo_dark_background</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/yadro_dark_background</item>
        <!-- Background -->
        <item name="android:windowBackground">@color/yadro_dark_background</item>
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/photo_ivory_text</item>
        <item name="android:textColorSecondary">@color/photo_grey_text</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="FullScreenBottomSheetDialog" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>