<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_nav"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/userHomeFragment"
        android:name="com.example.kotlinroomdatabase.fragments.list.User_Interface"
        android:label="Меню"
        tools:layout="@layout/user_ui" >
        <action
            android:id="@+id/action_userHome_to_history"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/listFragment"
        android:name="com.example.kotlinroomdatabase.fragments.list.ListFragment"
        android:label="Students"
        tools:layout="@layout/fragment_list" >
        <action
            android:id="@+id/action_listFragment_to_addFragment"
            app:destination="@id/addFragment" />
        <action
            android:id="@+id/action_listFragment_to_updateFragment"
            app:destination="@id/updateFragment" />
        <action
            android:id="@+id/action_listFragment_to_nfcAttendanceFragment"
            app:destination="@id/nfcAttendanceFragment" />
    </fragment>

    <fragment
        android:id="@+id/addFragment"
        android:name="com.example.kotlinroomdatabase.fragments.add.AddFragment"
        android:label="Add"
        tools:layout="@layout/fragment_add" >
        <action
            android:id="@+id/action_addFragment_to_listFragment"
            app:destination="@id/listFragment" />
    </fragment>

    <fragment
        android:id="@+id/updateFragment"
        android:name="com.example.kotlinroomdatabase.fragments.update.UpdateFragment"
        android:label="Update"
        tools:layout="@layout/fragment_update" >
        <action
            android:id="@+id/action_updateFragment_to_listFragment"
            app:destination="@id/listFragment" />
        <argument
            android:name="currentUser"
            app:argType="com.example.kotlinroomdatabase.model.User" />
    </fragment>

    <fragment
        android:id="@+id/nfcAttendanceFragment"
        android:name="com.example.kotlinroomdatabase.fragments.nfc.NFC_AttendanceFragment"
        android:label="NFC Attendance"
        tools:layout="@layout/fragment_nfc_checker" >
        <action
            android:id="@+id/action_nfcAttendanceFragment_to_listFragment"
            app:destination="@id/listFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.kotlinroomdatabase.data.LoginFragment"
        android:label="Вход">

        <action
            android:id="@+id/action_login_to_userHome"
            app:destination="@id/userHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_lessonFragment"
            app:destination="@id/lessonFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/lessonFragment"
        android:name="com.example.kotlinroomdatabase.fragments.list.LessonFragment"
        android:label="Занятие" >
        <action
            android:id="@+id/action_lessonFragment_to_listFragment"
            app:destination="@id/listFragment" />
        <action
            android:id="@+id/action_lessonFragment_to_history"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.kotlinroomdatabase.fragments.profile.ProfileFragment"
        android:label="Профиль"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.kotlinroomdatabase.fragments.history.HistoryFragment"
        android:label="История"
        tools:layout="@layout/fragment_history" >
        <argument
            android:name="studentId"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="subjectId"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.kotlinroomdatabase.fragments.settings.SettingsFragment"
        android:label="Настройки"
        tools:layout="@layout/fragment_settings" />
</navigation>